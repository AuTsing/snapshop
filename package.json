{
    "name": "snapshop",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vp dev",
        "build": "vue-tsc -b && vp build",
        "preview": "vp preview",
        "build:vscode": "vue-tsc -b && vp build --mode vscode-production",
        "watch:vscode": "vp build --mode vscode-development"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@vitejs/plugin-vue": "^6.0.0",
        "@vue/tsconfig": "^0.9.0",
        "typescript": "^5.0.0",
        "vite": "npm:@voidzero-dev/vite-plus-core@latest",
        "vite-plus": "latest",
        "vue-tsc": "^3.0.0",
        "vue": "^3.0.0",
        "ant-design-vue": "^4.0.0",
        "@ant-design/icons-vue": "^7.0.0",
        "@vueuse/core": "^14.0.0",
        "axios": "^1.0.0",
        "jimp": "0.16.1",
        "pinia": "^3.0.0",
        "unplugin-vue-components": "^32.0.0",
        "vite-plugin-singlefile": "^2.0.0",
        "vue-router": "^5.0.0"
    },
    "packageManager": "pnpm@10.33.0",
    "pnpm": {
        "overrides": {
            "vite": "npm:@voidzero-dev/vite-plus-core@latest",
            "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
        }
    }
}
