{
    "name": "snapshop",
    "version": "0.0.0",
    "scripts": {
        "dev": "vp dev --host",
        "build": "vue-tsc --noEmit && vp build",
        "build:vscode": "vue-tsc --noEmit && vp build --config vite.config.vscode.ts --mode vscode-production",
        "watch:vscode": "vp build --config vite.config.vscode.ts --mode vscode-development",
        "preview": "vue-tsc --noEmit && vp build && vp preview",
        "prepare": "vp config"
    },
    "devDependencies": {
        "@ant-design/icons-vue": "^7.0.0",
        "@types/node": "^22.0.0",
        "@vitejs/plugin-vue": "^6.0.0",
        "@vueuse/core": "^14.0.0",
        "ant-design-vue": "^3.2.20",
        "axios": "^1.0.0",
        "jimp": "0.16.1",
        "less": "^4.1.3",
        "pinia": "^3.0.0",
        "typescript": "^5.0.0",
        "unplugin-vue-components": "^32.0.0",
        "vite": "npm:@voidzero-dev/vite-plus-core@latest",
        "vite-plugin-singlefile": "^2.0.0",
        "vue": "^3.0.0",
        "vue-router": "^5.0.0",
        "vue-tsc": "^3.0.0",
        "vite-plus": "latest"
    },
    "packageManager": "npm@11.12.1",
    "overrides": {
        "vite": "npm:@voidzero-dev/vite-plus-core@latest",
        "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
}
